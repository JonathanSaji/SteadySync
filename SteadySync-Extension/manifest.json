{
  "manifest_version": 3,
  "name": "SteadySync",
  "version": "1.0",
  "description": "Adaptive UI and tremor filtering for a smoother browsing experience.",
  "permissions": ["scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
  
}